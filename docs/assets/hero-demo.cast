[0.014, "o", "\u001b[H\u001b[J\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n  \u001b[0;35m\u001b[1m🔬 Step 3: Profiling — Finding the Optimal Config\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[0;36m# First, Dynamo discovers your hardware: \u001b[1;33m\u001b[1m32× H100\u001b[0m\u001b[0;36m on the cluster.\u001b[0m\r\n\u001b[0;36m# It sets sensible defaults — \u001b[1;33m\u001b[1mSLA: TTFT ≤ 500ms · ITL ≤ 30ms\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;36m# then generates the optimal config that meets these requirements — no manual tuning.\u001b[0m\r\n\r\n"]
