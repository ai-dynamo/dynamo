[0.000, "o", "\r\n\r\n\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m"]
[0.000, "o", "\r\n"]
[0.001, "o", "  \u001b[0;35m\u001b[1m🚀 Let's deploy Qwen3-235B with Dynamo!\u001b[0m\r\n\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n\u001b[0;36m# It's one step: \u001b[1;37mkubectl apply\u001b[0m\u001b[0;36m → go make coffee ☕ → it's live.\u001b[0m\r\n\r\n"]
[0.000, "o", "   \u001b[2mQwen/Qwen3-235B-A22B-FP8 · trtllm · disaggregated prefill/decode\u001b[0m\r\n"]
[4.501, "o", "\r\n\r\n\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n  \u001b[0;35m\u001b[1m📝 Step 1: Specify Your Model\u001b[0m\r\n"]
[0.001, "o", "\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n\r\n"]
[0.000, "o", "\u001b[0;36m# Name a model. That's the only required field.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[2.202, "o", "apiVersion: nvidia.com/v1beta1\r\n"]
[0.092, "o", "kind: DynamoGraphDeploymentRequest\r\n"]
[0.092, "o", "metadata:\r\n"]
[0.091, "o", "  name: qwen3-235b\r\n"]
[0.092, "o", "spec:\r\n"]
[0.092, "o", "  model: Qwen/Qwen3-235B-A22B-FP8\r\n"]
[3.894, "o", "\r\n"]
[3.802, "o", "\r\n\r\n\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n  \u001b[0;35m\u001b[1m🚀 Step 2: Apply — The Only kubectl You'll Run\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n\r\n"]
[0.000, "o", "\u001b[0;36m# One command. Then you're done.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[2.202, "o", "\u001b[0;32m❯\u001b[0m kubectl apply -f qwen3-235b.yaml\r\ndynamographdeploymentrequest.nvidia.com/qwen3-235b created\r\n"]
[3.802, "o", "\r\n\u001b[0;32m❯\u001b[0m kubectl get dgdr qwen3-235b -n dynamo-system\r\nNAME          MODEL                      BACKEND   PHASE       PROFILING        DGD             AGE\r\nqwen3-235b    Qwen/Qwen3-235B-A22B-FP8   trtllm    Profiling   Initializing                     4s\r\n"]
