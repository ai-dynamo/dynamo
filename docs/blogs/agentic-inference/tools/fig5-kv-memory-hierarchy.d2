...@dynamo.d2

vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

gpu: "GPU (HBM)" {
  class: gpu
  style.font-size: 24
  width: 500
  latency: "~ns" {
    shape: text
    style: {
      font-size: 18
      font-color: "#76b900"
    }
  }
  cap: "Fastest, smallest" {
    shape: text
    style: {
      font-size: 14
      font-color: "#8a8a8a"
      italic: true
    }
  }
}

cpu: "CPU (pinned DRAM)" {
  class: cpu
  style.font-size: 24
  width: 500
  latency: "~us" {
    shape: text
    style: {
      font-size: 18
      font-color: "#3d7ab5"
    }
  }
  cap: "10-100x GPU capacity" {
    shape: text
    style: {
      font-size: 14
      font-color: "#8a8a8a"
      italic: true
    }
  }
}

nvme: "Local NVMe" {
  class: cache
  style.font-size: 24
  width: 500
  latency: "~ms" {
    shape: text
    style: {
      font-size: 18
      font-color: "#50a090"
    }
  }
  cap: "TBs per node" {
    shape: text
    style: {
      font-size: 14
      font-color: "#8a8a8a"
      italic: true
    }
  }
}

remote: "Remote Storage (NIXL)" {
  class: event
  style.font-size: 24
  width: 500
  latency: "~ms (RDMA)" {
    shape: text
    style: {
      font-size: 18
      font-color: "#c08050"
    }
  }
  cap: "Cluster-wide, shared" {
    shape: text
    style: {
      font-size: 14
      font-color: "#8a8a8a"
      italic: true
    }
  }
}

gpu -> cpu: "offload" {
  class: data_flow
  style.font-size: 18
}

cpu -> nvme: "write-through" {
  class: data_flow
  style.font-size: 18
}

nvme -> remote: "replicate" {
  class: data_flow
  style.font-size: 18
}
