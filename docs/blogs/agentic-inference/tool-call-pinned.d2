direction: right

prefill1: "Prefill" {
  shape: rectangle
  style.font-size: 24
}

decode1: "Decode" {
  shape: rectangle
  style.font-size: 24
}

tool: "Tool Call (30s)" {
  shape: rectangle
  style.font-size: 24
  style.fill: "#f5f5f5"
  style.stroke: "#999999"
}

pinned: "Cache Pinned" {
  shape: rectangle
  style.font-size: 22
  style.fill: "#f0fff0"
  style.stroke: "#4a9e4a"
  style.font-color: "#4a9e4a"
}

decode2: "Decode" {
  shape: rectangle
  style.font-size: 24
}

prefill1 -> decode1: {
  style.stroke-width: 2
}

decode1 -> tool: {
  style.stroke-width: 2
}

tool -> pinned: "retention API" {
  style.stroke-width: 2
  style.stroke: "#4a9e4a"
  style.font-size: 22
  style.font-color: "#4a9e4a"
}

pinned -> decode2: "no re-prefill" {
  style.stroke-width: 2
  style.stroke: "#4a9e4a"
  style.font-size: 22
  style.font-color: "#4a9e4a"
}
