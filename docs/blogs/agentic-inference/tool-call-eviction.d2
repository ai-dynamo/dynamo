direction: right

prefill1: "Prefill" {
  shape: rectangle
  style.font-size: 24
}

decode1: "Decode" {
  shape: rectangle
  style.font-size: 24
}

tool: "Tool Call (30s)" {
  shape: rectangle
  style.font-size: 24
  style.fill: "#f5f5f5"
  style.stroke: "#999999"
}

eviction: "KV Evicted" {
  shape: rectangle
  style.font-size: 22
  style.fill: "#fff0f0"
  style.stroke: "#cc4444"
  style.font-color: "#cc4444"
}

prefill2: "Re-Prefill" {
  shape: rectangle
  style.font-size: 24
  style.fill: "#fff0f0"
  style.stroke: "#cc4444"
  style.font-color: "#cc4444"
}

decode2: "Decode" {
  shape: rectangle
  style.font-size: 24
}

prefill1 -> decode1: {
  style.stroke-width: 2
}

decode1 -> tool: {
  style.stroke-width: 2
}

tool -> eviction: "LRU ages out blocks" {
  style.stroke-width: 2
  style.stroke: "#cc4444"
  style.font-size: 22
  style.font-color: "#cc4444"
}

eviction -> prefill2: "full recompute" {
  style.stroke-width: 2
  style.stroke: "#cc4444"
  style.font-size: 22
  style.font-color: "#cc4444"
}

prefill2 -> decode2: {
  style.stroke-width: 2
}
