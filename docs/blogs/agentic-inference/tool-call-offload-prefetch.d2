direction: right

vars: {
  d2-config: {
    theme-overrides: {
      N1: "#e0e0e0"
      N2: "#a0a0a0"
      N3: "#707070"
      N4: "#404040"
      N5: "#5d5d5d"
      N6: "#151515"
      N7: "#0a0a0a"

      B1: "#0a0a0a"
      B2: "#111111"
      B3: "#181818"
      B4: "#222222"
      B5: "#5d5d5d"
      B6: "#404040"

      AA2: "#76b900"
      AA4: "#3d7ab5"
      AA5: "#c4a035"

      AB4: "#7a3050"
      AB5: "#2a6b55"
    }
  }
}

call1: "LLM Call 1" {
  style: {
    fill: "#2a4a10"
    stroke: "#76b900"
    stroke-width: 2
    font-color: "#e0e0e0"
    font-size: 20
    bold: true
    border-radius: 0
  }
}

storage: "Host Memory / Storage" {
  style: {
    fill: "#0f1e30"
    stroke: "#3d7ab5"
    stroke-width: 2
    font-color: "#e0e0e0"
    font-size: 20
    bold: true
    border-radius: 0
  }
}

call2: "LLM Call 2" {
  style: {
    fill: "#2a4a10"
    stroke: "#76b900"
    stroke-width: 2
    font-color: "#e0e0e0"
    font-size: 20
    bold: true
    border-radius: 0
  }
}

call1 -> storage: "KV offload during tool call" {
  style: {
    stroke: "#c4a035"
    stroke-width: 2
    font-color: "#c4a035"
    font-size: 16
  }
}

storage -> call2: "KV prefetch before next call" {
  style: {
    stroke: "#76b900"
    stroke-width: 2
    font-color: "#76b900"
    font-size: 16
  }
}
