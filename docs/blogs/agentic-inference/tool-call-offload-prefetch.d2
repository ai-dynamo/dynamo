grid-rows: 3
grid-gap: 80

# Row 1: GPU timeline
timeline: {
  direction: right
  grid-columns: 4
  grid-gap: 0

  prefill1: "LLM Prefill 1" {
    shape: rectangle
    style.font-size: 24
  }

  call1: "LLM Call 1" {
    shape: rectangle
    style.font-size: 24
  }

  tool: "Tool Call (30s)" {
    shape: rectangle
    style.font-size: 24
    style.fill: "#f5f5f5"
    style.stroke: "#999999"
  }

  call2: "LLM Call 2" {
    shape: rectangle
    style.font-size: 24
  }
}

# Row 2: Host Memory
host: "Host Memory" {
  shape: rectangle
  style.font-size: 24
}

# Row 3: Storage
storage: "Storage" {
  shape: cylinder
  style.font-size: 24
}

# Connections
timeline.call1 -> host: "KV Offload" {
  style.stroke-width: 2
  style.font-size: 22
}

host -> timeline.call2: "KV Prefetch" {
  style.stroke-width: 2
  style.font-size: 22
}

host -> storage: {
  style.stroke-width: 2
}
