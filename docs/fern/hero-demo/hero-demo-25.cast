[1.002, "o", "\r\n   apiVersion:  nvidia.com/v1alpha1\r\n   kind:        DynamoGraphDeployment\r\n   name:        trtllm-disagg\r\n\r\n   services:\r\n"]
[0.000, "o", "   Service                            Replicas   GPUs         Type\r\n   -------------------------------- ---------- ------ ------------\r\n"]
[0.000, "o", "   Frontend                                  1      -     frontend\r\n"]
[0.000, "o", "   TRTLLMDecodeWorker  (decode)              2      8       worker\r\n   TRTLLMPrefillWorker (prefill)             4      4       worker\r\n\r\n"]
[0.000, "o", "   \u001b[1mTotal GPU allocation: 32 GPUs\u001b[0m"]
[0.000, "o", "\r\n"]
[1.002, "o", "\r\n   \u001b[0;34mFrontend\u001b[0m в”Җв”Җв–¶ \u001b[0;34mPrefill Г—4\u001b[0m в”Җв”Җв–¶ \u001b[0;34mDecode Г—2\u001b[0m      \u001b[0;35m[ 32 GPUs В· disagg ]\u001b[0m\r\n   \u001b[0;35m(router)     (4 GPU ea)     (8 GPU ea)\u001b[0m\r\n   \u001b[0;34mSLA Planner в–ё\u001b[0m watches TTFT/ITL, auto-scales prefill & decode\r\n"]
