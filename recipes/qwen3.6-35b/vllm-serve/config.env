#
# Per-config metadata sourced by the unified run-benchmark.sh.
# Sibling to deploy.yaml / perf.yaml — keeps each config self-contained.
#
# DEPLOY_KIND branches deploy() + clean() in the driver:
#   deployment → kubectl rollout status + delete Deployment+Service
#   dgd        → kubectl wait on operator-stamped DGD pod labels + delete DGD
export CONFIG_NAME="vllm-serve"
export DEPLOY_KIND="deployment"
export DEPLOY_NAME="qwen36-vllm-serve"
export BENCH_POD="qwen36-bench"
