#
# Hardware target: H100 (x86) on aws-dev-02.
#
# Image is the RUNTIME image baked from Dynamo main (vLLM 0.22.0 + nixl
# 1.1.0 + dynamo prebuilt), which carries vLLM PR #41869 (GDN P/D over
# NIXL). Built + pushed via:
#   mcp__cloud-session__build_image(local_path=<this worktree>,
#       framework=vllm, target=runtime, platform=linux/amd64, push=True)
# This is a PRIVATE nvstaging tag — after deploy, patch the DGD's
# ServiceAccount with ${IMAGE_PULL_SECRET} (default ngc-pull-secret); see
# README -> Usage step 2.
export VLLM_IMAGE="nvcr.io/nvstaging/ai-dynamo/vllm-runtime:qiwa-efa-vllm-x86-06-05"

# IMPORTANT for disagg: leave the node selector EMPTY. Each worker requests
# gpu:"8", so on 8-GPU nodes the prefill and decode pods land on SEPARATE
# nodes by scheduler placement (1P1D = 2 nodes). Do NOT hostname-pin both
# workers to one node — they won't both fit.
# If the cluster is contended and gang-scheduling stalls (kai-scheduler
# Pending), pin each worker to a distinct free node by splitting this into
# per-service selectors (see README -> Scheduling).
export HW_NODE_SELECTOR='{}'

# H100 nodes carry no special taint — empty toleration array.
export HW_TOLERATIONS='[]'

# Secret (in the target namespace) holding nvcr.io/nvstaging pull creds.
export IMAGE_PULL_SECRET="ngc-pull-secret"
