# Load deployment-local cluster placement without committing or transferring it.
_campaign_env_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -r "${_campaign_env_dir}/campaign.local.env" ]]; then
  # shellcheck disable=SC1091
  source "${_campaign_env_dir}/campaign.local.env"
fi
unset _campaign_env_dir

glm52_require_cluster_env() {
  local name
  for name in "$@"; do
    if [[ -z "${!name:-}" ]]; then
      echo "Missing ${name}; copy campaign.local.env.example to campaign.local.env and fill it in." >&2
      return 1
    fi
  done
}

