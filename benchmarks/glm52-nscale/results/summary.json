  "issues": [
    {
      "id": "swebench-dockerhub-pull-rate-limit",
      "variant": "dynamo-vllm / swebench-verified / ab",
      "severity": "high",
      "status": "fixed",
      "error": "The initial full Dynamo + vLLM A/B Verified evaluation reached Docker Hub's anonymous pull limit after 189 valid reports; a first same-run resume recovered 294 more reports before 17 remaining image pulls hit the same limit.",
      "impact": "Both partial attempts failed closed with benchmark_score null and were excluded from official results; generation remained complete and the 483 valid evaluator reports were preserved.",
      "fix": "After quota replenished, the 17 missing task images were staged serially into the existing Docker daemon and each image ID and RepoDigest was matched to generation-time task-images.json evidence. The unchanged prediction-digest run then reused 483 reports and evaluated only the remaining 17 instances.",
      "verification": "The final guarded resume completed 500/500 reports with zero evaluator errors and stable serving continuity. The strict artifact reports 436 resolved, 64 unresolved, benchmark_score 0.872, and was accepted by the immutable importer."
    },
    {
      "id": "setup-dynamo-vllm-tool-routing",
      "variant": "dynamo-vllm",
      "severity": "medium",
      "status": "fixed",
      "error": "The initial Dynamo frontend recipe did not explicitly match standalone vLLM's GLM automatic-tool and reasoning parsing path.",
      "impact": "Forced and automatic tool calls could diverge between the two vLLM variants before comparative evaluation.",
      "fix": "Enabled automatic tool choice on the Dynamo frontend and pinned the glm47 tool parser plus glm45 reasoning parser.",
      "verification": "Exact-text, forced-tool, and automatic-tool smoke requests pass; the fail-closed BFCL validation set passed 5/5 with zero inference errors."
    },
    {
      "id": "bfcl-partial-evaluation-fail-open",
      "variant": "all variants",
      "severity": "high",
      "status": "fixed",
      "error": "Upstream partial BFCL evaluation could exit zero after malformed or incomplete generation output.",
      "impact": "An incomplete BFCL run could have been mistaken for valid benchmark evidence.",
      "fix": "Added exact generated/scored population gates, category accounting, inference-error rejection, immutable resume metadata, and independent weighted-score recomputation.",
      "verification": "The pinned five-case smoke gate rejects incomplete output and passed 5/5 against every validated serving path; full imports require all 5,217 generated and 5,106 scored IDs."
    },
    {
      "id": "terminalbench-infrastructure-fail-open",
      "variant": "all variants",
      "severity": "high",
      "status": "fixed",
      "error": "The first Terminal-Bench runner lacked Docker Compose v2, while Harbor emitted infrastructure exceptions but returned a zero process status.",
      "impact": "Three infrastructure-invalid trials could have been reported as a passing harness invocation.",
      "fix": "Pinned Docker 27.5.1 and Compose 2.33.0, mounted the required runner paths into DinD, and made exceptions, missing rewards, or incomplete task sets fail closed.",
      "verification": "The corrected strict validation run completed all three pinned tasks at 3/3 reward with zero exceptions."
    },
    {
      "id": "terminalbench-generation-contract",
      "variant": "all variants",
      "severity": "medium",
      "status": "fixed",
      "error": "Harbor 0.17.1 recorded max_output_tokens for accounting but did not forward it on Chat Completions, and its default 900-second task timeout was too short for the published GLM-5.2 settings.",
      "impact": "Early calibrations used non-representative output limits or terminated valid long-running tasks as infrastructure failures.",
      "fix": "Pinned the published Terminus-2 sampling contract at temperature 1.0, top-p 1.0, 48,000 output tokens, 256K advertised task context, and a 14,400-second task timeout.",
      "verification": "The replacement smoke produced terminating turns and the corrected strict three-task run completed in 37 minutes at 3/3 reward with zero exceptions."
    },
    {
      "id": "evaluator-transport-disconnect",
      "variant": "all variants",
      "severity": "high",
      "status": "fixed",
      "error": "A long foreground kubectl exec lost its Teleport transport and left an orphaned evaluator process without a valid continuity attestation.",
      "impact": "The interrupted partial result was invalid and could not be imported; another disconnect could have wasted a multi-hour full cell.",
      "fix": "Moved evaluator ownership to a detached runner-side supervisor with atomic locking and state publication, bounded reconnectable control calls, explicit cancellation, process-group cleanup, and fail-closed postflight attestation.",
