# Copy to campaign.local.env and fill in the deployment-local values. The local
# file is ignored and is never included in evaluation-runner source bundles.
KUBE_CONTEXT="<kubectl-context>"
NAMESPACE="<campaign-namespace>"
NODE_NAME="<eight-gpu-b200-node>"
EXPECTED_GPU_UUIDS="<four-comma-separated-gpu-uuids>"
