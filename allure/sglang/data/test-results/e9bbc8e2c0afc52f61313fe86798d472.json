472-278c23f423cd-attachment.txt","ext":".txt","name":"log","contentType":"text/plain","used":true,"missed":false,"contentLength":17703},"type":"attachment"},{"link":{"id":"e7e54924d12ff606425f4a05eabf0ff3","originalFileName":"f1ce2365-7d79-416c-a51a-9ef7dfc31aad-attachment.txt","ext":".txt","name":"stdout","contentType":"text/plain","used":true,"missed":false,"contentLength":279405},"type":"attachment"},{"link":{"id":"4c31c2ec1309a5f1dec5e22fd76f4998","originalFileName":"cf51264b-1dd6-4089-8bda-3085b3715ca9-attachment.txt","ext":".txt","name":"stderr","contentType":"text/plain","used":true,"missed":false,"contentLength":23634},"type":"attachment"}],"error":{},"testCase":{"id":"34bb47fb6a1e65285045068fa35a1e64","name":"test_etcd_ha_failover_sglang_disaggregated","fullName":"tests.fault_tolerance.etcd_ha.test_sglang#test_etcd_ha_failover_sglang_disaggregated"},"descriptionHtml":"<pre><code>Test ETCD High Availability with repeated node failures and recoveries in disaggregated mode using SGLang.\n\nThis test:\n1. Starts a 3-node ETCD cluster\n2. Starts NATS, frontend, and both prefill and decode SGLang workers\n3. Cycles through each of the 3 replicas:\n   - Terminate the replica by index\n   - Send inference request to verify system still works\n   - Restart the terminated node\n\nThis ensures testing of:\n- ETCD leader termination\n- Frontend/worker disconnection from their connected ETCD replica\n\nNote: This test requires 2 GPUs to run decode and prefill workers on separate GPUs.\n</code></pre>\n","environment":"sglang-amd64","setup":[{"id":"83fb81b0c483a80353b1a16256fa9679","type":"before","name":"predownload_models","status":"passed","steps":[],"duration":9490},{"id":"cc73fd8a1eaaaae3469729e0097411c9","type":"before","name":"pytestconfig","status":"passed","steps":[],"duration":0},{"id":"b665629ba09a0b491cf762260ec032ab","type":"before","name":"logger","status":"passed","steps":[],"duration":0},{"id":"1e03a0b01436f630a6a9cb3dedcfde11","type":"before","name":"set_