eName":"e7da28e3-64f9-48ce-bfc9-4fe51eee0fe6-attachment.txt","ext":".txt","contentType":"text/plain","contentLength":17707,"name":"log"},"type":"attachment"},{"link":{"used":true,"missed":false,"id":"b18a424781e61c483723c15f10cacc85","originalFileName":"daa5d5ac-ad93-47b5-9825-3434e5904372-attachment.txt","ext":".txt","contentType":"text/plain","contentLength":282741,"name":"stdout"},"type":"attachment"},{"link":{"id":"f517c43d7fd45d7a49c70a137a6b0c55","originalFileName":"511f49b6-a821-4071-9766-9099d6662be7-attachment.txt","ext":".txt","name":"stderr","contentType":"text/plain","used":true,"missed":false,"contentLength":23638},"type":"attachment"}],"error":{},"testCase":{"id":"34bb47fb6a1e65285045068fa35a1e64","name":"test_etcd_ha_failover_sglang_disaggregated","fullName":"tests.fault_tolerance.etcd_ha.test_sglang#test_etcd_ha_failover_sglang_disaggregated"},"descriptionHtml":"<pre><code>Test ETCD High Availability with repeated node failures and recoveries in disaggregated mode using SGLang.\n\nThis test:\n1. Starts a 3-node ETCD cluster\n2. Starts NATS, frontend, and both prefill and decode SGLang workers\n3. Cycles through each of the 3 replicas:\n   - Terminate the replica by index\n   - Send inference request to verify system still works\n   - Restart the terminated node\n\nThis ensures testing of:\n- ETCD leader termination\n- Frontend/worker disconnection from their connected ETCD replica\n\nNote: This test requires 2 GPUs to run decode and prefill workers on separate GPUs.\n</code></pre>\n","environment":"sglang-amd64","setup":[{"id":"9f4448c60aa0a6b804a6a3bb674dc0f6","type":"before","name":"pytestconfig","status":"passed","steps":[],"duration":0},{"id":"a05b496be0eb949cfd06f792f1f50d69","type":"before","name":"predownload_models","status":"passed","steps":[],"duration":8665},{"id":"838b4fcbbb0848844dfc9d149f413bb8","type":"before","name":"logger","status":"passed","steps":[],"duration":0},{"id":"a3552c7a5f8662ed82fb6a1cb0dc60fe","type":"before","name":"set