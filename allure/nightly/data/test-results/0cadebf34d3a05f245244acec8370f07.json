nd inference request to verify system still works\n       - Restart the terminated node\n\n    This ensures testing of:\n    - ETCD leader termination\n    - Frontend/worker disconnection from their connected ETCD replica\n\n    Note: This test requires 2 GPUs to run decode and prefill workers on separate GPUs.\n    ","flaky":false,"muted":false,"known":false,"hidden":true,"labels":[{"name":"dynamo_workflow","value":"Nightly CI Pipeline"},{"name":"dynamo_framework","value":"sglang"},{"name":"dynamo_platform","value":"amd64"},{"name":"dynamo_testType","value":"pre_merge_gpu"},{"name":"tag","value":"nightly"},{"name":"tag","value":"e2e"},{"name":"tag","value":"gpu_2"},{"name":"tag","value":"fault_tolerance"},{"name":"tag","value":"sglang"},{"name":"parentSuite","value":"tests.fault_tolerance.etcd_ha"},{"name":"suite","value":"test_sglang"},{"name":"host","value":"prod-tester-amd-gpu-4-v1-vdpdj-runner-jkt5n"},{"name":"thread","value":"95-MainThread"},{"name":"framework","value":"pytest"},{"name":"language","value":"cpython3"},{"name":"package","value":"tests.fault_tolerance.etcd_ha.test_sglang"}],"steps":[{"link":{"used":true,"missed":false,"id":"6cc9ad6bc97d66442cb25ef08a91aa6c","originalFileName":"b2f858e2-18df-401c-b002-76e725d92a40-attachment.txt","ext":".txt","contentType":"text/plain","contentLength":17707,"name":"log"},"type":"attachment"},{"link":{"id":"ba59cb6eacfb1d730c0ca774a2905291","originalFileName":"7804914a-4712-4b84-b11c-eea06d3673c4-attachment.txt","ext":".txt","name":"stdout","contentType":"text/plain","used":true,"missed":false,"contentLength":281129},"type":"attachment"},{"link":{"id":"9f44b3c7c785eb8d95b9090d9df0ff1b","originalFileName":"b7f11ad7-75ca-4c97-9650-2cb4d2cf5f5c-attachment.txt","ext":".txt","name":"stderr","contentType":"text/plain","used":true,"missed":false,"contentLength":23638},"type":"attachment"}],"parameters":[{"name":"framework","value":"'sglang'","hidden":false,"excluded":false,"masked":false},{"name":"platform","value":"'amd6