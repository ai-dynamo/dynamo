+        idx += 32
+        if idx < cutlass.const_expr(self.data_dim // 16):
+            src = k_data_slice[page_id, block_offset, (None, idx)]
+            cute.copy(
+                cp16_atom,
+                cute.recast_tensor(src, Uint32),
+                s_kdata_slice[(None, idx), stage_id],
+            )
+        elif idx == cutlass.const_expr(self.data_dim // 16):
