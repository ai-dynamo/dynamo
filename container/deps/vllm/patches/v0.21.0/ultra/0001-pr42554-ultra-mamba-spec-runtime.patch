+                    k_data_slice,
+                    k_scale,
+                    block_table,
+                    s_kdata_16B_slice,
+                    s_kscale,
+                    req_id,
+                    next_pos,
+                    lane_id,
+                    prefetch_stage,
+                )
+                prefetch_stage = (prefetch_stage + 1) % self.num_stages
+            cute.arch.cp_async_commit_group()
+
+            # Wait for gmem->smem to finish.
+            cute.arch.cp_async_wait_group(self.num_stages - 1)
+            cute.arch.sync_warp()
