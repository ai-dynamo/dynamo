+        )
+        self.block_table_stride_req = int(next(iter(strides)))
+        for i, bt in enumerate(block_tables):
+            self.block_table_ptrs[i] = bt.data_ptr()
+
+        self.is_initialized = True
+
+    def run_fused_postprocess(
