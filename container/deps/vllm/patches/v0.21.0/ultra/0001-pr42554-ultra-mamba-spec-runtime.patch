+                    k_data_slice,
+                    k_scale,
+                    block_table,
+                    s_kdata_16B_slice,
+                    s_kscale,
+                    req_id,
+                    next_pos,
+                    lane_id,
+                    i,
+                )
+            cute.arch.cp_async_commit_group()
