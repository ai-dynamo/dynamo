+# ── IPC packed transfer ────────────────────────────────────────────────
+
+
+@dataclass
+class PackedIpcChunk:
+    """Metadata and IPC handle for a single packed chunk."""
+
+    names: list[str]
+    shapes: list[list[int]]
+    dtype_names: list[str]
+    tensor_sizes: list[int]
+    ipc_handle: dict[str, tuple]
