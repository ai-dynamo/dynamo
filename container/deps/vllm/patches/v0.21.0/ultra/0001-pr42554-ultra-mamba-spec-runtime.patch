+            f"IPC handle not found for GPU UUID {physical_gpu_id}. "
+            f"Available UUIDs: {list(ipc_handle.keys())}"
+        )
+
+    args = ipc_handle[physical_gpu_id]
+    list_args = list(args)
+    list_args[6] = device_index
