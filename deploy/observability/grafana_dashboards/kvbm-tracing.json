{
  "editable": true,
  "graphTooltip": 2,
  "panels": [
    {
      "title": "Search Traces (click a row to view waterfall)",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ name = \"llm_request\" }",
          "limit": 30,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "View waterfall",
              "url": "/d/kvbm-tracing/kvbm-tracing?var-traceId=${__data.fields.traceID}&from=now-3h&to=now"
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "traceDuration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ns"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "startTime",
            "desc": true
          }
        ]
      }
    },
    {
      "title": "Slow Requests (highest TTFT first — click row for waterfall)",
      "description": "Top 20 slowest requests by TTFT. Shows vllm.first_token spans sorted by ttft_ms descending. Click a row to drill into the trace waterfall.",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ name = \"vllm.first_token\" } | select(span.ttft_ms, span.request_id)",
          "limit": 20,
          "tableType": "spans"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "ttft_ms",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "View waterfall",
              "url": "/d/kvbm-tracing/kvbm-tracing?var-traceId=${__data.fields.traceID}&from=now-3h&to=now"
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ttft_ms"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "TTFT (ms)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "request_id"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Request ID"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "traceDuration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ns"
              },
              {
                "id": "displayName",
                "value": "Trace Duration"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "TTFT (ms)",
            "desc": true
          }
        ]
      }
    },
    {
      "title": "Trace Waterfall: ${traceId}",
      "type": "traces",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "${traceId}"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "ttft_ms",
                "desc": false
              }
            ]
          }
        }
      ]
    },
    {
      "title": "Scheduler State (per-iteration snapshot)",
      "description": "Live counts from build_connector_metadata: how many requests are new, cached (continuing), onboarding, or finishing each scheduler tick.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 66
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "onboarding"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "new"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cached"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "finishing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "kvbm_scheduler_new_requests{job=\"kvbm-metrics\"}",
          "legendFormat": "new"
        },
        {
          "expr": "kvbm_scheduler_cached_requests{job=\"kvbm-metrics\"}",
          "legendFormat": "cached"
        },
        {
          "expr": "kvbm_scheduler_onboarding{job=\"kvbm-metrics\"}",
          "legendFormat": "onboarding"
        },
        {
          "expr": "kvbm_scheduler_finishing{job=\"kvbm-metrics\"}",
          "legendFormat": "finishing"
        }
      ]
    },
    {
      "title": "Scheduler Inflight Requests",
      "description": "Total inflight requests tracked by the KVBM leader across all states.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 66
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "gradientMode": "scheme"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "inflight"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "kvbm_scheduler_inflight{job=\"kvbm-metrics\"}",
          "legendFormat": "inflight"
        }
      ]
    },
    {
      "title": "KVBM Cache Hit Rates (host / disk / remote)",
      "description": "Sliding-window hit rates reported by the KVBM leader on port 6880.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 74
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "host"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "disk"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "remote"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "kvbm_host_cache_hit_rate{job=\"kvbm-metrics\"}",
          "legendFormat": "host"
        },
        {
          "expr": "kvbm_disk_cache_hit_rate{job=\"kvbm-metrics\"}",
          "legendFormat": "disk"
        },
        {
          "expr": "kvbm_remote_cache_hit_rate{job=\"kvbm-metrics\"}",
          "legendFormat": "remote"
        }
      ]
    },
    {
      "title": "KVBM Block Counts (cumulative)",
      "description": "Cumulative onboard/offload block counters from the KVBM leader.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 74
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "kvbm_onboard_blocks_h2d{job=\"kvbm-metrics\"}",
          "legendFormat": "onboard H→D"
        },
        {
          "expr": "kvbm_onboard_blocks_d2d{job=\"kvbm-metrics\"}",
          "legendFormat": "onboard D→D"
        },
        {
          "expr": "kvbm_onboard_blocks_r2d{job=\"kvbm-metrics\"}",
          "legendFormat": "onboard R→D"
        },
        {
          "expr": "kvbm_offload_blocks_d2h{job=\"kvbm-metrics\"}",
          "legendFormat": "offload D→H"
        },
        {
          "expr": "kvbm_offload_blocks_h2d{job=\"kvbm-metrics\"}",
          "legendFormat": "offload H→D"
        },
        {
          "expr": "kvbm_offload_blocks_d2r{job=\"kvbm-metrics\"}",
          "legendFormat": "offload D→R"
        }
      ]
    },
    {
      "title": "Remote Transfer Latency (KVBM native histogram)",
      "description": "Latency histogram from the KVBM leader's own Prometheus endpoint — broken down by direction and backend.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 82
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, direction, backend) (rate(kvbm_remote_transfer_latency_seconds_bucket{job=\"kvbm-metrics\"}[5m])))",
          "legendFormat": "{{direction}}/{{backend}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, direction, backend) (rate(kvbm_remote_transfer_latency_seconds_bucket{job=\"kvbm-metrics\"}[5m])))",
          "legendFormat": "{{direction}}/{{backend}} p95"
        }
      ]
    },
    {
      "title": "Remote Bytes Transferred (GB/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 82
      },
      "fieldConfig": {
        "defaults": {
          "unit": "GBs",
          "custom": {
            "fillOpacity": 20,
