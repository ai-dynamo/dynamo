        {
          "expr": "rate(kvbm_onboard_bytes_remote{job=\"kvbm-metrics\"}[1m]) / 1e9",
          "legendFormat": "onboard GB/s"
        }
      ]
    },
    {
      "title": "Onboard Latency (R2H + H2D) p50/p95  [span-metrics]",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "P1809F7CD0C75ACF3"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 90
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
