    {
      "title": "Concurrent Request Timeline",
      "description": "Shows all recent requests on a shared time axis. Each row is a request, colored segments show lifecycle stage. Use the time picker to zoom into a burst of concurrent requests.",
      "type": "state-timeline",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ name =~ \"kvbm.get_matched_tokens|kvbm.worker_remote_transfer|vllm.prefill_scheduled|vllm.first_token|vllm.finished\" && span.request_id != \"\" } | select(span.request_id)",
          "limit": 200,
          "tableType": "spans"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "traceID": false,
              "spanID": true,
              "traceService": true,
              "traceName": true,
              "service.name": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "Start time",
                "desc": false
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "links": [
            {
              "title": "View waterfall",
              "url": "/d/kvbm-tracing/kvbm-tracing?var-traceId=${__data.fields.traceID}&from=now-1h&to=now"
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": false,
        "alignValue": "left",
        "rowHeight": 0.8,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
