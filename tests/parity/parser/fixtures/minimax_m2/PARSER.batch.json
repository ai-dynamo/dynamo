{
  "family": "minimax_m2",
  "mode": "batch",
  "cases": {
    "1": {
      "description": "Single tool call (happy path)",
      "model_text": "<minimax:tool_call>\n<invoke name=\"get_weather\">\n<parameter name=\"location\">NYC</parameter>\n</invoke>\n</minimax:tool_call>",
      "tools": [
        {
          "name": "get_weather",
          "parameters": {
            "type": "object",
            "properties": {
              "location": {
                "type": "string"
              }
            }
          }
        }
      ],
      "expected": {
        "calls": [
          {
            "name": "get_weather",
            "arguments": {
              "location": "NYC"
            }
          }
        ],
        "normal_text": ""
      }
    },
