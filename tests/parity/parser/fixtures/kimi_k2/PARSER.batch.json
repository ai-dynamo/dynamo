          }
        }
      ],
      "expected": {
        "calls": [
          {
            "name": "get_weather",
            "arguments": {
              "location": "NYC"
            }
          },
          {
            "name": "get_weather",
            "arguments": {
              "location": "LA"
            }
          }
        ],
        "normal_text": ""
      }
    }
  }
