*                   text  eol=lf
*.sln               text  eol=crlf
*.[Ii][Cc][Oo]      binary
*.[Jj][Pp][Ee][Gg]  binary
*.[Jj][Pp][Gg]      binary
*.[Pp][Dd][Ff]      binary
*.[Pp][Nn][Gg]      binary
*.[Ww][Ee][Bb][Pp]  binary
*.[Zz][Ii][Pp]      binary
*.[Tt][Gg][Zz]      binary
*.[Gg][Zz]          binary
*.fatbin            binary
*.mp4               binary

# Unified-diff context lines in vendored patches can look like blank trailing whitespace.
container/deps/sglang_patches/*.patch whitespace=-blank-at-eol,-blank-at-eof,-space-before-tab

# Exclude test data files from linguist language detection
lib/llm/tests/data/** linguist-vendored
lib/llm/tests/snapshots/** linguist-vendored
