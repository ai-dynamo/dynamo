<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Dynamo Local Resource Monitor</title>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<style>
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: #0d0d14;
    color: #e0e0e0;
    font-family: monospace;
    overflow: hidden;
  }
  #toolbar {
    height: 52px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    border-bottom: 1px solid #2a2a3c;
  }
  h1 { margin: 0; font-size: 20px; font-weight: 700; }
  .btn {
    border: 1px solid #444466;
    padding: 6px 12px;
    cursor: pointer;
    font-family: monospace;
    font-weight: 700;
    border-radius: 4px;
    font-size: 13px;
    background: #2a2a3c;
    color: #e0e0e0;
  }
  .btn.active { background: #55557a; }
  #pause-btn { background: #ffcc00; color: #0d0d14; border-color: #ffcc00; }
  #snapshot-btn { background: #00e676; color: #0d0d14; border-color: #00e676; }
  #chart { width: 100vw; height: calc(100vh - 74px); }
  #status { height: 22px; padding-left: 16px; font-size: 11px; color: #9a9aaa; }
</style>
</head>
<body>
<div id="toolbar">
  <h1>Dynamo Local Resource Monitor</h1>
  <div>
    <button class="btn range-btn" data-sec="60">1m</button>
    <button class="btn range-btn active" data-sec="120">2m</button>
    <button class="btn range-btn" data-sec="300">5m</button>
    <button class="btn range-btn" data-sec="900">15m</button>
    <button class="btn" id="pause-btn">Pause</button>
    <button class="btn" id="snapshot-btn">Snapshot</button>
  </div>
</div>
<div id="chart"></div>
<div id="status">Connecting...</div>

<script>
(function() {
  "use strict";

  const MAX_POINTS = 5000;
  let state = null;
  let viewSeconds = 120;
  let paused = false;
  let renderScheduled = false;
  let lastCounters = {main: 0, disk: 0, pcie: []};
  const status = document.getElementById("status");
  const chart = document.getElementById("chart");

  const socket = io({
    transports: ["websocket", "polling"],
    reconnection: true,
    reconnectionDelay: 500,
    reconnectionAttempts: Infinity,
    timeout: 60000
  });

  socket.on("connect", function() {
    status.textContent = "Connected. Waiting for data...";
    socket.emit("view_minutes", Math.max(1, Math.round(viewSeconds / 60)));
    socket.emit("request_init");
  });

  socket.on("disconnect", function() {
    status.textContent = "Disconnected -- reconnecting...";
  });

  socket.on("init", function(msg) {
    state = msg;
    lastCounters = {
      main: msg.counter_main || 0,
      disk: msg.counter_disk || 0,
      pcie: msg.counter_pcie || []
    };
    if (msg.hostname) {
      const gpuTag = msg.gpu_summary ? " " + msg.gpu_summary : "";
      const title = "Dynamo Local Resource Monitor - " + msg.hostname + gpuTag;
      document.querySelector("h1").textContent = title;
      document.title = title;
    }
    scheduleRender();
  });

  socket.on("delta", function(msg) {
    if (!state) {
      socket.emit("request_init");
      return;
    }
    if (keysChanged(msg)) {
      socket.emit("request_init");
      return;
    }
    mergeDelta(msg);
    scheduleRender();
  });

  function keysChanged(msg) {
    if (!msg.gpu_mem_keys || !state.gpu_mem) return false;
    const currentGpu = state.gpu_mem.map(group => group.map(p => p.pid));
    if (!sameKeySet(currentGpu, msg.gpu_mem_keys)) return true;
    const currentCpu = (state.cpu_procs || []).map(p => p.id);
    if (!sameKeySet([currentCpu], [msg.cpu_proc_keys || []])) return true;
    return false;
  }

  function sameKeySet(a, b) {
    if (!a || !b || a.length !== b.length) return false;
    const normalize = groups => groups.map(group => {
      if (!Array.isArray(group)) return group;
      return group.map(value => String(value)).sort();
    });
    return JSON.stringify(normalize(a)) === JSON.stringify(normalize(b));
  }

  function appendTrim(arr, vals) {
    if (!vals || vals.length === 0) return;
    arr.push.apply(arr, vals);
    if (arr.length > MAX_POINTS) arr.splice(0, arr.length - MAX_POINTS);
  }

  function appendById(existing, incoming, key) {
    const byKey = new Map(existing.map(item => [item[key], item]));
    for (const item of incoming || []) {
      const target = byKey.get(item[key]);
      if (target) appendTrim(target.vals, item.vals || []);
    }
  }

  function mergeDelta(msg) {
    appendTrim(state.ts_main, msg.ts_main || []);
    appendTrim(state.ts_disk, msg.ts_disk || []);
    appendTrim(state.cpu, msg.cpu || []);
    appendById(state.cpu_procs || [], msg.cpu_procs || [], "id");
    appendTrim(state.net_sent, msg.net_sent || []);
    appendTrim(state.net_recv, msg.net_recv || []);
    appendTrim(state.disk_read, msg.disk_read || []);
    appendTrim(state.disk_write, msg.disk_write || []);
    for (let gi = 0; gi < (state.gpu_count || 0); gi++) {
      appendById(state.gpu_mem[gi] || [], (msg.gpu_mem || [])[gi] || [], "pid");
      appendTrim(state.gpu_util[gi], (msg.gpu_util || [])[gi] || []);
      appendTrim(state.gpu_temp[gi], (msg.gpu_temp || [])[gi] || []);
      appendTrim(state.ts_pcie[gi] || [], (msg.ts_pcie || [])[gi] || []);
      appendTrim(state.pcie_tx[gi] || [], (msg.pcie_tx || [])[gi] || []);
      appendTrim(state.pcie_rx[gi] || [], (msg.pcie_rx || [])[gi] || []);
    }
    lastCounters = {
      main: msg.counter_main || lastCounters.main,
      disk: msg.counter_disk || lastCounters.disk,
      pcie: msg.counter_pcie || lastCounters.pcie
    };
  }

  function toDates(values) {
    return (values || []).map(v => new Date(v * 1000));
  }

  function scheduleRender() {
    if (renderScheduled) return;
    renderScheduled = true;
    requestAnimationFrame(function() {
      renderScheduled = false;
      render();
    });
  }

  function visibleRange() {
    if (paused || viewSeconds <= 0) return null;
    const end = new Date();
    const start = new Date(end.getTime() - viewSeconds * 1000);
    return [start, end];
  }

  function render() {
    if (!state) return;
    const traces = [];
    const timesMain = toDates(state.ts_main);
    const timesDisk = toDates(state.ts_disk);
    const colors = [
      "#00e5ff", "#ff1744", "#76ff03", "#448aff", "#ff9100",
      "#d500f9", "#ffea00", "#f50057", "#00e676", "#ff6d00"
    ];

    for (let gi = 0; gi < (state.gpu_count || 0); gi++) {
      const memSeries = state.gpu_mem[gi] || [];
      for (let i = memSeries.length - 1; i >= 0; i--) {
        const proc = memSeries[i];
        traces.push({
          x: timesMain, y: proc.vals, name: "GPU " + gi + " " + proc.name + " (" + proc.pid + ")",
          type: "scatter", mode: "none", stackgroup: "gpu_mem_" + gi,
          fillcolor: hexToRgba(proc.color || colors[i % colors.length], 0.55),
          line: {width: 0, color: proc.color || colors[i % colors.length]},
          xaxis: "x", yaxis: "y", legendgroup: "gpu_mem_" + gi
        });
      }
      traces.push({
        x: timesMain,
        y: timesMain.map(() => (state.gpu_mem_total_gib || [])[gi] || 0),
        name: "GPU " + gi + " total",
        type: "scatter", mode: "lines", line: {color: "#ff5252", width: 1, dash: "dot"},
        xaxis: "x", yaxis: "y", legendgroup: "gpu_total"
      });
      traces.push({
        x: timesMain, y: (state.gpu_util || [])[gi] || [], name: "GPU " + gi + " util",
        type: "scatter", mode: "lines", line: {color: "#76b900", width: 2},
        fill: "tozeroy", fillcolor: "rgba(118,185,0,0.25)", xaxis: "x2", yaxis: "y2"
      });
      traces.push({
        x: timesMain, y: (state.gpu_temp || [])[gi] || [], name: "GPU " + gi + " temp",
        type: "scatter", mode: "lines", line: {color: "#ff6e40", width: 1, dash: "dot"},
        xaxis: "x2", yaxis: "y2"
      });
      if (state.has_pcie) {
        const timesPcie = toDates((state.ts_pcie || [])[gi] || []);
        traces.push({
          x: timesPcie, y: (state.pcie_tx || [])[gi] || [], name: "GPU " + gi + " PCIe TX",
          type: "scatter", mode: "lines", line: {color: "#ef5350", width: 1}, xaxis: "x4", yaxis: "y4"
        });
        traces.push({
          x: timesPcie, y: (state.pcie_rx || [])[gi] || [], name: "GPU " + gi + " PCIe RX",
          type: "scatter", mode: "lines", line: {color: "#69f0ae", width: 1, dash: "dot"}, xaxis: "x4", yaxis: "y4"
        });
      }
    }

    for (const proc of state.cpu_procs || []) {
      traces.push({
        x: timesMain, y: proc.vals, name: proc.name, type: "scatter", mode: "none",
        stackgroup: "cpu", fillcolor: hexToRgba(proc.color || "#8888ff", 0.45),
        line: {width: 0, color: proc.color || "#8888ff"}, xaxis: "x3", yaxis: "y3"
      });
    }
    traces.push({
      x: timesMain, y: state.cpu || [], name: "CPU total", type: "scatter", mode: "lines",
      line: {color: "#ffcc00", width: 1.5, dash: "dot"}, xaxis: "x3", yaxis: "y3"
    });
    traces.push({
      x: timesDisk, y: state.disk_read || [], name: "Disk read", type: "scatter", mode: "lines",
      line: {color: "#ff9800", width: 1}, xaxis: "x4", yaxis: "y4"
    });
    traces.push({
      x: timesDisk, y: state.disk_write || [], name: "Disk write", type: "scatter", mode: "lines",
      line: {color: "#ffd740", width: 1}, xaxis: "x4", yaxis: "y4"
    });
    traces.push({
      x: timesMain, y: state.net_sent || [], name: "Net TX", type: "scatter", mode: "lines",
      line: {color: "#18ffff", width: 1}, xaxis: "x4", yaxis: "y4"
    });
    traces.push({
      x: timesMain, y: state.net_recv || [], name: "Net RX", type: "scatter", mode: "lines",
      line: {color: "#ff80ab", width: 1}, xaxis: "x4", yaxis: "y4"
    });

    const range = visibleRange();
    const baseAxis = {gridcolor: "#262640", zerolinecolor: "#444466"};
    const xAxis = {gridcolor: "#262640", type: "date"};
    if (range) xAxis.range = range;
    const layout = {
      paper_bgcolor: "#0d0d14", plot_bgcolor: "#141420",
      font: {family: "monospace", color: "#e0e0e0", size: 11},
      margin: {l: 68, r: 20, t: 20, b: 34},
      hovermode: "x unified",
      legend: {orientation: "v", x: 1.01, y: 1, bgcolor: "rgba(13,13,20,0.75)", font: {size: 10}},
      grid: {rows: 4, columns: 1, pattern: "independent", roworder: "top to bottom"},
      xaxis: Object.assign({}, xAxis),
      xaxis2: Object.assign({}, xAxis),
      xaxis3: Object.assign({}, xAxis),
      xaxis4: Object.assign({}, xAxis),
      yaxis: Object.assign({title: "GPU VRAM GiB", domain: [0.76, 1.0], rangemode: "tozero"}, baseAxis),
      yaxis2: Object.assign({title: "GPU % / C", domain: [0.52, 0.72], range: [0, 105]}, baseAxis),
      yaxis3: Object.assign({title: "CPU %", domain: [0.28, 0.48], range: [0, 105]}, baseAxis),
      yaxis4: Object.assign({title: "I/O", domain: [0.0, 0.24], rangemode: "tozero"}, baseAxis),
      annotations: [
        label("GPU VRAM by process", 0.995),
        label("GPU utilization + temperature", 0.715),
        label("CPU total + top process groups", 0.475),
        label("Disk, network, PCIe", 0.235)
      ]
    };
    Plotly.react(chart, traces, layout, {responsive: true, displayModeBar: true, scrollZoom: true});
    const gpuText = state.gpu_count ? state.gpu_count + " GPU" + (state.gpu_count === 1 ? "" : "s") : "CPU-only";
    status.textContent = (paused ? "Paused" : "Live") +
      " | " + gpuText +
      " | main " + lastCounters.main +
      " disk " + lastCounters.disk;
  }

  function label(text, y) {
    return {
      text: "  " + text + "  ",
      x: 0,
      y: y,
      xref: "paper",
      yref: "paper",
      showarrow: false,
      xanchor: "left",
      yanchor: "top",
      bgcolor: "rgba(30,30,50,0.92)",
      bordercolor: "#444466",
      borderwidth: 1,
      font: {size: 11, color: "#c0c0d0"}
    };
  }

  function hexToRgba(hex, alpha) {
    const h = (hex || "#999999").replace("#", "");
    const r = parseInt(h.substring(0, 2), 16);
    const g = parseInt(h.substring(2, 4), 16);
    const b = parseInt(h.substring(4, 6), 16);
    return "rgba(" + r + "," + g + "," + b + "," + alpha + ")";
  }

  document.querySelectorAll(".range-btn").forEach(btn => {
    btn.addEventListener("click", function() {
      document.querySelectorAll(".range-btn").forEach(b => b.classList.remove("active"));
      this.classList.add("active");
      viewSeconds = parseInt(this.dataset.sec);
      paused = false;
      document.getElementById("pause-btn").textContent = "Pause";
      document.getElementById("pause-btn").style.backgroundColor = "#ffcc00";
      socket.emit("view_minutes", Math.max(1, Math.round(viewSeconds / 60)));
      scheduleRender();
    });
  });

  document.getElementById("pause-btn").addEventListener("click", function() {
    paused = !paused;
    this.textContent = paused ? "Resume" : "Pause";
    this.style.backgroundColor = paused ? "#ff5252" : "#ffcc00";
    if (!paused) socket.emit("view_minutes", Math.max(1, Math.round(viewSeconds / 60)));
    scheduleRender();
  });

  document.getElementById("snapshot-btn").addEventListener("click", function() {
    if (!state) return;
    const d = new Date();
    const pad = n => String(n).padStart(2, "0");
    const fname = d.getFullYear() + "-" +
      pad(d.getMonth() + 1) + "-" +
      pad(d.getDate()) + "_" +
      pad(d.getHours()) +
      pad(d.getMinutes()) +
      pad(d.getSeconds()) +
      "_resource_monitor";
    Plotly.downloadImage(chart, {format: "png", width: 1920, height: 1080, scale: 2, filename: fname});
  });
})();
</script>
</body>
</html>