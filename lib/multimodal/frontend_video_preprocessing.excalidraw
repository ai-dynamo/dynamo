      "text": "ProcessedMedia { modality: video,\n  pixel_values_videos: F32 [patches, 1536]\n    layout = flat(\"patches_per_video\"), forward = true\n  video_grid_thw: I64 [1, 3]\n    layout = batched, keep_on_host = true\n  timestamps: F64 [1, grid_t]\n    layout = batched, keep_on_host = true\n  patches_per_video: I64 [1]\n    layout helper, forward = false\n  feature_token_counts, original_sizes\n}", "originalText": "ProcessedMedia { modality: video,\n  pixel_values_videos: F32 [patches, 1536]\n    layout = flat(\"patches_per_video\"), forward = true\n  video_grid_thw: I64 [1, 3]\n    layout = batched, keep_on_host = true\n  timestamps: F64 [1, grid_t]\n    layout = batched, keep_on_host = true\n  patches_per_video: I64 [1]\n    layout helper, forward = false\n  feature_token_counts, original_sizes\n}",
