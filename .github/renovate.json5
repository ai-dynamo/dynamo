// Renovate config for the production GitOps profile.
//
// Coverage:
//   * All ArgoCD Applications under deploy/production/gitops/{apps,optional}/
//     -- Renovate's native `argocd` manager bumps `targetRevision` on
//     each Helm chart and git-sourced reference.
//   * SMG-specific image tag in addons/smg/values.yaml (custom regex).
//   * Sibling Postgres image tag in addons/smg-postgres/postgres.yaml
//     (custom regex matching `image: postgres:X.Y-alpine`).
//
// Update policy:
//   * patch + minor -> auto-merge after CI passes (preferred per
//     ai-blaise/dynamo-prod-k8s#1 follow-up: "automatic updating is
//     preferred").
//   * major -> open PR with `needs-human-review` label. Major bumps to
//     SMG, the Dynamo platform chart, kube-prometheus-stack, and the
//     GPU operator each carry contract changes that should be read
//     deliberately, not auto-merged.
//
// Add a new addon? Renovate's argocd manager picks it up automatically
// from the gitops/apps/ directory -- no config edit needed unless the
// addon also pins something *outside* an ArgoCD Application (image tags
// inside a values.yaml, for instance). For those, add a customManagers
// entry following the SMG and Postgres patterns below.
{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended", ":prHourlyLimitNone"],

  // Native argocd manager: walks YAML files looking for ArgoCD
  // Application kinds and bumps targetRevision. Limit the search to
  // the production GitOps tree so Renovate doesn't churn on docs or
  // examples.
  argocd: {
    managerFilePatterns: [
      "deploy/production/gitops/apps/.*\\.yaml$",
      "deploy/production/gitops/optional/.*\\.yaml$",
    ],
  },

  packageRules: [
    // Auto-merge ArgoCD-tracked chart bumps for patch + minor.
    {
      matchManagers: ["argocd"],
      matchUpdateTypes: ["patch", "minor"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
    },
    // Major chart bumps must be reviewed.
    {
      matchManagers: ["argocd"],
      matchUpdateTypes: ["major"],
      automerge: false,
      labels: ["needs-human-review"],
    },
    // SMG image tag: same auto/manual split as the chart.
    {
      matchPackageNames: ["lightseekorg/smg"],
      matchUpdateTypes: ["patch", "minor"],
      groupName: "smg",
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
    },
    {
      matchPackageNames: ["lightseekorg/smg"],
      matchUpdateTypes: ["major"],
      automerge: false,
      labels: ["needs-human-review"],
    },
    // Sibling Postgres for SMG history.
    {
      matchPackageNames: ["postgres"],
      matchUpdateTypes: ["patch", "minor"],
      groupName: "smg-postgres",
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
    },
    {
      matchPackageNames: ["postgres"],
      matchUpdateTypes: ["major"],
      automerge: false,
      labels: ["needs-human-review"],
    },
  ],

  customManagers: [
    // SMG router image tag pinned in the addon values.yaml.
    {
      customType: "regex",
      managerFilePatterns: ["deploy/production/addons/smg/values\\.yaml$"],
      matchStrings: [
        "repository:\\s*lightseekorg/smg\\s*\\n\\s*tag:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
      ],
      depNameTemplate: "lightseekorg/smg",
      datasourceTemplate: "docker",
      registryUrlTemplate: "https://ghcr.io",
    },
    // Sibling Postgres image (postgres:X.Y-alpine) inside the
    // hand-rolled StatefulSet for SMG's history backend.
    {
      customType: "regex",
      managerFilePatterns: ["deploy/production/addons/smg-postgres/postgres\\.yaml$"],
      matchStrings: [
        "image:\\s*postgres:(?<currentValue>[0-9]+\\.[0-9]+)-alpine",
      ],
      depNameTemplate: "postgres",
      datasourceTemplate: "docker",
      versioningTemplate: "docker",
    },
  ],
}
